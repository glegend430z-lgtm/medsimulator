# Server
PORT=3000
NODE_ENV=development

# Frontend URLs allowed by CORS
FRONTEND_URL=http://localhost:3001
FRONTEND_ORIGINS=http://localhost:3001,http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:3000

# Database
DATABASE_PROVIDER=mysql
DATABASE_URL=mysql://user:password@localhost:3306/MedSimulator_core_hms_v2
# Render PostgreSQL example after tested migration:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/MedSimulator_core_hms

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=1d
PASSWORD_MIN_LENGTH=12
AUTH_FAILED_LOGIN_DELAY_MAX_MS=2500
STEP_UP_TTL_SECONDS=300
STEP_UP_ENFORCEMENT_ENABLED=false

# Cache, rate limit, and request safety
REDIS_URL=
CACHE_PREFIX=inv_hms
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DASHBOARD_TTL_SECONDS=30
CACHE_REFERENCE_TTL_SECONDS=300
CACHE_IN_MEMORY_MAX_ITEMS=10000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
SEARCH_RATE_LIMIT_MAX=60
DASHBOARD_RATE_LIMIT_MAX=120
PDF_RATE_LIMIT_MAX=20
MPESA_RATE_LIMIT_MAX=5
PUBLIC_VERIFY_RATE_LIMIT_MAX=30
REQUEST_TIMEOUT_MS=30000
BODY_LIMIT=4mb
PDF_IMAGE_MAX_BYTES=512000

# AI assistant
# Keep this only on the backend environment. Never expose it in the frontend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Safaricom Daraja / M-PESA STK Push
# Use sandbox while testing, then production after Safaricom activates your live app.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-backend.example.com/billing/payments/mpesa/callback
# Paybill: CustomerPayBillOnline. Till/Buy Goods: CustomerBuyGoodsOnline.
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_PROMPT_LOCK_SECONDS=90
MPESA_MAX_CONCURRENT_PROMPTS=20
MPESA_REQUEST_TIMEOUT_MS=15000
MPESA_STATUS_CACHE_SECONDS=10

# Queue and worker mode
QUEUE_ENABLED=true
QUEUE_CONCURRENCY=5
QUEUE_PREFIX=inv_hms
WORKER_MODE=false

# ---------------------------------------------------------------------------
# KRA eTIMS fiscalization
# Disabled by default. Set ETIMS_ENABLED=true and ETIMS_MODE=sandbox or
# production to use the real OSCU API; ETIMS_MODE=mock uses the built-in
# mock adapter (no KRA connectivity required).
# ---------------------------------------------------------------------------
ETIMS_ENABLED=false
ETIMS_MODE=mock
# Required when ETIMS_MODE is sandbox/production:
ETIMS_BASE_URL=
ETIMS_TIN=
ETIMS_BHF_ID=00
# Device credential issued during OSCU device initialization. Secret.
ETIMS_CMC_KEY=
ETIMS_DEVICE_SERIAL=
ETIMS_TIMEOUT_MS=15000
ETIMS_MAX_ATTEMPTS=8
# Default KRA tax type: A = VAT exempt (medical services)
ETIMS_DEFAULT_TAX_CODE=A
ETIMS_VAT_RATE=16
# Override the receipt QR verification URL if KRA changes it:
ETIMS_RECEIPT_VERIFY_URL=

# ---------------------------------------------------------------------------
# DHA (Digital Health Agency) interoperability
# Disabled by default. DHA_MODE=mock uses the built-in mock adapter until
# production endpoints and credentials are issued.
# ---------------------------------------------------------------------------
DHA_ENABLED=false
DHA_MODE=mock
# Required when DHA_MODE is sandbox/production:
DHA_BASE_URL=
DHA_TOKEN_URL=
DHA_CLIENT_ID=
DHA_CLIENT_SECRET=
DHA_API_VERSION=v1
DHA_FACILITY_CODE=
DHA_TIMEOUT_MS=15000
DHA_MAX_ATTEMPTS=8

# Integration outbound queue worker
INTEGRATION_WORKER_ENABLED=true
INTEGRATION_WORKER_POLL_MS=5000
INTEGRATION_QUEUE_BATCH_SIZE=10
INTEGRATION_RETRY_BASE_DELAY_MS=30000
INTEGRATION_RETRY_MAX_DELAY_MS=3600000
INTEGRATION_STUCK_REQUEST_MS=600000

# Development-only password reset helpers
PASSWORD_RESET_BASE_URL=http://localhost:3001/reset-password
RETURN_DEV_RESET_TOKEN=false

# Render production examples:
# FRONTEND_URL=https://your-render-frontend.onrender.com
# FRONTEND_ORIGINS=https://your-render-frontend.onrender.com,https://your-custom-domain.example
# MPESA_CALLBACK_URL=https://your-render-backend.onrender.com/billing/payments/mpesa/callback
# PASSWORD_RESET_BASE_URL=https://your-render-frontend.onrender.com/reset-password
