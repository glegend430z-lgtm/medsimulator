  @@map("audit_logs")
}

model IpGeolocationCache {
  id             Int       @id @default(autoincrement())
  ipAddress      String    @unique @db.VarChar(100)
  country        String?   @db.VarChar(120)
  region         String?   @db.VarChar(120)
  city           String?   @db.VarChar(120)
  latitude       Float?
  longitude      Float?
  isp            String?   @db.VarChar(255)
  org            String?   @db.VarChar(255)
  timezone       String?   @db.VarChar(120)
  confidence     Float?
  source         String?   @db.VarChar(80)
  rawResponse    Json?
  lastLookedUpAt DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([expiresAt])
  @@index([country])
  @@index([city])
