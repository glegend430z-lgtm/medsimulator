model UserLocationProfile {
  id                Int       @id @default(autoincrement())
  userId            Int?
  sessionId         String    @unique @db.VarChar(120)
  sessionVersion    Int?
  isOnline          Boolean   @default(true)
  loginAt           DateTime?
  lastSeenAt        DateTime  @default(now())
  loggedOutAt       DateTime?
  lastRoute         String?   @db.VarChar(500)
  lastMethod        String?   @db.VarChar(10)
  lastStatusCode    Int?
  ipAddress         String?   @db.VarChar(100)
  userAgent         String?   @db.Text
  country           String?   @db.VarChar(120)
  region            String?   @db.VarChar(120)
  city              String?   @db.VarChar(120)
  latitude          Float?
  longitude         Float?
  accuracyMeters    Float?
  isp               String?   @db.VarChar(255)
  org               String?   @db.VarChar(255)
  timezone          String?   @db.VarChar(120)
  confidence        Float?
  geolocationSource String?   @db.VarChar(80)
  deviceType        String?   @db.VarChar(80)
  browser           String?   @db.VarChar(120)
  operatingSystem   String?   @db.VarChar(120)
  eventCount        Int       @default(0)
