model SystemSetting {
  id           Int      @id @default(autoincrement())
  settingKey   String   @unique @db.VarChar(100)
  settingValue String   @db.Text
  valueType    String?  @db.VarChar(50)
  category     String?  @db.VarChar(100)
  description  String?  @db.Text
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@map("system_settings")
}

model Notification {
  id               Int     @id @default(autoincrement())
  title            String  @db.VarChar(200)
  message          String  @db.Text
  notificationType String? @db.VarChar(50)
  severity         String? @db.VarChar(20)
  moduleName       String? @db.VarChar(100)
  entityType       String? @db.VarChar(100)
  entityId         String? @db.VarChar(100)

  facilityId    Int?
  branchId      Int?
  targetUserId  Int?
  targetStaffId Int?

  isRead Boolean   @default(false)
  readAt DateTime?

  isResolved        Boolean   @default(false)
  resolvedAt        DateTime?
  resolvedByUserId  Int?
  resolvedByStaffId Int?
  resolutionNote    String?   @db.Text

  createdAt DateTime @default(now())

  facility    Facility? @relation(fields: [facilityId], references: [id])
  branch      Branch?   @relation(fields: [branchId], references: [id])
  targetUser  User?     @relation("NotificationTargetUser", fields: [targetUserId], references: [id])
  targetStaff Staff?    @relation("NotificationTargetStaff", fields: [targetStaffId], references: [id])

  resolvedByUser  User?  @relation("NotificationResolvedByUser", fields: [resolvedByUserId], references: [id])
  resolvedByStaff Staff? @relation("NotificationResolvedByStaff", fields: [resolvedByStaffId], references: [id])

  @@index([facilityId])
  @@index([branchId])
  @@index([targetUserId])
  @@index([targetStaffId])
  @@index([isRead])
  @@index([isResolved])
  @@index([moduleName])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([facilityId, branchId, isResolved, createdAt])
  @@index([targetUserId, isRead, createdAt])
  @@index([targetStaffId, isRead, createdAt])
  @@index([moduleName, isResolved, createdAt])
  @@index([resolvedByUserId])
  @@index([resolvedByStaffId])
  @@map("notifications")
}

model BranchMedicineStock {
  id            Int      @id @default(autoincrement())
  facilityId    Int
  branchId      Int
  medicineId    Int
  stockQuantity Int      @default(0)
  reorderLevel  Int      @default(0)
  buyingPrice   Float    @default(0)
  unitPrice     Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  medicine Medicine @relation(fields: [medicineId], references: [id])
  stockMovements PharmacyStockMovement[]

  @@unique([branchId, medicineId])
  @@index([facilityId])
  @@index([branchId])
  @@index([medicineId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([facilityId, branchId, isActive])
  @@index([branchId, stockQuantity])
  @@index([branchId, updatedAt])
  @@map("branch_medicine_stocks")
}

model OtcSale {
  id               Int      @id @default(autoincrement())
  saleNumber       String   @unique @db.VarChar(50)
  saleType         String   @default("OTC") @db.VarChar(20)
  customerName     String?  @db.VarChar(150)
  customerPhone    String?  @db.VarChar(30)
  status           String   @default("DRAFT") @db.VarChar(50)
  paymentStatus    String   @default("UNPAID") @db.VarChar(50)
  subtotal         Float    @default(0)
  discountAmount   Float    @default(0)
  taxAmount        Float    @default(0)
  totalAmount      Float    @default(0)
  paidAmount       Float    @default(0)
  balanceAmount    Float    @default(0)
  soldAt           DateTime?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  facilityId       Int
  branchId         Int
  patientId        Int?
  createdByStaffId Int

  facility  Facility      @relation(fields: [facilityId], references: [id])
  branch    Branch        @relation(fields: [branchId], references: [id])
  patient   Patient?      @relation(fields: [patientId], references: [id])
  createdBy Staff        @relation("OtcSaleCreatedByStaff", fields: [createdByStaffId], references: [id])
  items     OtcSaleItem[]
  payments  OtcSalePayment[]
  stockMovements PharmacyStockMovement[]

  @@index([facilityId])
  @@index([branchId])
  @@index([patientId])
  @@index([createdByStaffId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([soldAt])
  @@index([facilityId, branchId, status, createdAt])
  @@map("otc_sales")
}

model OtcSaleItem {
  id                   Int      @id @default(autoincrement())
  saleId               Int
  medicineId           Int
  medicineNameSnapshot String   @db.VarChar(180)
  dosageFormSnapshot   String?  @db.VarChar(100)
  strengthSnapshot     String?  @db.VarChar(100)
  quantity             Int      @default(1)
  unitPrice            Float    @default(0)
  lineTotal            Float    @default(0)
  stockBefore          Int?
  stockAfter           Int?
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sale      OtcSale   @relation(fields: [saleId], references: [id])
  medicine  Medicine  @relation(fields: [medicineId], references: [id])
  stockMovements PharmacyStockMovement[]

  @@index([saleId])
  @@index([medicineId])
  @@map("otc_sale_items")
}

model OtcSalePayment {
  id                      Int       @id @default(autoincrement())
  saleId                  Int
  facilityId              Int
  branchId                Int
  paymentMethod           String    @db.VarChar(50)
  statusCode              String    @default("COMPLETED") @db.VarChar(50)
  amount                  Float     @default(0)
  transactionRef          String?   @db.VarChar(120)
  phoneNumber             String?   @db.VarChar(30)
  mpesaReceiptNumber      String?   @db.VarChar(100)
  merchantRequestId       String?   @db.VarChar(100)
  checkoutRequestId       String?   @db.VarChar(100)
  insuranceProviderName   String?   @db.VarChar(150)
  insuranceSchemeName     String?   @db.VarChar(150)
  insuranceMemberNumber   String?   @db.VarChar(120)
  principalMemberName     String?   @db.VarChar(150)
  relationshipToPrincipal String?   @db.VarChar(80)
  authorizationNumber     String?   @db.VarChar(120)
  policyNumber            String?   @db.VarChar(120)
  insuranceCoveredAmount  Float     @default(0)
  patientCoPayAmount      Float     @default(0)
  insuranceClaimReference String?   @db.VarChar(120)
  insuranceClaimStatus    String?   @db.VarChar(50)
  paidAt                  DateTime?
  requestedAt             DateTime  @default(now())
  confirmedAt             DateTime?
  receivedByStaffId       Int?
  notes                   String?   @db.Text
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  sale       OtcSale  @relation(fields: [saleId], references: [id])
  facility   Facility @relation(fields: [facilityId], references: [id])
  branch     Branch   @relation(fields: [branchId], references: [id])
  receivedBy Staff?   @relation("OtcSalePaymentReceivedByStaff", fields: [receivedByStaffId], references: [id])

  @@index([saleId])
  @@index([facilityId])
  @@index([branchId])
  @@index([paymentMethod])
  @@index([statusCode])
  @@index([insuranceClaimStatus])
  @@index([mpesaReceiptNumber])
  @@index([checkoutRequestId])
  @@index([createdAt])
  @@index([facilityId, branchId, paymentMethod, createdAt])
  @@map("otc_sale_payments")
}

model PharmacyStockMovement {
  id              Int      @id @default(autoincrement())
  facilityId      Int
  branchId        Int
  medicineId      Int
  branchStockId   Int?
  sourceType      String   @db.VarChar(50)
  sourceEntityId  String?  @db.VarChar(100)
  movementType    String   @db.VarChar(50)
  quantity        Int
  stockBefore     Int
  stockAfter      Int
  otcSaleId       Int?
  otcSaleItemId   Int?
  performedByStaffId Int?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  facility    Facility             @relation(fields: [facilityId], references: [id])
  branch      Branch               @relation(fields: [branchId], references: [id])
  medicine    Medicine             @relation(fields: [medicineId], references: [id])
  branchStock BranchMedicineStock? @relation(fields: [branchStockId], references: [id])
  otcSale     OtcSale?             @relation(fields: [otcSaleId], references: [id])
  otcSaleItem OtcSaleItem?         @relation(fields: [otcSaleItemId], references: [id])
  performedBy Staff?               @relation("PharmacyStockMovementStaff", fields: [performedByStaffId], references: [id])

  @@index([facilityId])
  @@index([branchId])
  @@index([medicineId])
  @@index([branchStockId])
  @@index([sourceType])
  @@index([movementType])
  @@index([otcSaleId])
  @@index([otcSaleItemId])
  @@index([performedByStaffId])
  @@index([createdAt])
  @@index([facilityId, branchId, sourceType, createdAt])
  @@map("pharmacy_stock_movements")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
