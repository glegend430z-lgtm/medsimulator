generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Facility {
  id                      Int                           @id @default(autoincrement())
  code                    String                        @unique @db.VarChar(50)
  branchCode              String?                       @unique @db.VarChar(50)
  name                    String                        @db.VarChar(255)
  facilityType            String?                       @db.VarChar(100)
  county                  String?                       @db.VarChar(120)
  town                    String?                       @db.VarChar(120)
  country                 String?                       @db.VarChar(120)
  phone                   String?                       @db.VarChar(50)
  altPhone                String?                       @db.VarChar(50)
  email                   String?                       @db.VarChar(255)
  website                 String?                       @db.VarChar(255)
  address                 String?                       @db.VarChar(255)
  postalAddress           String?                       @db.VarChar(255)
  registrationNo          String?                       @db.VarChar(100)
  taxPin                  String?                       @db.VarChar(100)
  licenseNumber           String?                       @db.VarChar(100)
  logoUrl                 String?                       @db.LongText
  timezone                String?                       @db.VarChar(100)
  currency                String?                       @db.VarChar(20)
  mpesaShortcode          String?                       @db.VarChar(50)
  mpesaPaybill            String?                       @db.VarChar(50)
  mpesaTillNumber         String?                       @db.VarChar(50)
  isHeadOffice            Boolean                       @default(false)
  isDefault               Boolean                       @default(false)
  isActive                Boolean                       @default(true)
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  mpesaAccountNumber      String?                       @db.VarChar(80)
  mpesaPochiNumber        String?                       @db.VarChar(80)
  latitude                Float?
  longitude               Float?
  mapLocationLabel        String?                       @db.VarChar(255)
  googleMapsUrl           String?                       @db.VarChar(500)
  showCashOnInvoice       Boolean                       @default(true)
  showPaybillOnInvoice    Boolean                       @default(true)
  showTillOnInvoice       Boolean                       @default(true)
  showPochiOnInvoice      Boolean                       @default(true)
  shaFidCode              String?                       @db.VarChar(120)
  shaClaimStartNumber     Int                           @default(1)
  shaClaimNextNumber      Int                           @default(1)
  subscriptionMonthlyFee  Float                         @default(5000)
  subscriptionStartedAt   DateTime?
  subscriptionPaidThrough DateTime?
  subscriptionStatus      String                        @default("ACTIVE") @db.VarChar(50)
  subscriptionLockedAt    DateTime?
  mpesaEnabled            Boolean                       @default(false)
  mpesaEnvironment        String?                       @db.VarChar(30)
  mpesaConsumerKey        String?                       @db.LongText
  mpesaConsumerSecret     String?                       @db.LongText
  mpesaPasskey            String?                       @db.LongText
  mpesaCallbackUrl        String?                       @db.VarChar(500)
  mpesaTransactionType    String?                       @db.VarChar(80)
  complianceStatus        String                        @default("COMPLIANT") @db.VarChar(50)
  complianceReason        String?                       @db.Text
  complianceDeactivatedAt DateTime?
  complianceGraceEndsAt   DateTime?
  complianceReactivatedAt DateTime?
  admissions              Admission[]
  appointments            Appointment[]
  auditLogs               AuditLog[]
  beds                    Bed[]
  branchMedicineStocks    BranchMedicineStock[]
  branches                Branch[]
  clinics                 Clinic[]
  consultations           Consultation[]
  departments             Department[]
  dispenses               Dispense[]
  subscriptionPayments    FacilitySubscriptionPayment[]
  invoices                Invoice[]
  labOrders               LabOrder[]
  notifications           Notification[]
  otcSalePayments         OtcSalePayment[]
  otcSales                OtcSale[]
  patients                Patient[]
  payments                Payment[]
  pharmacyStockMovements  PharmacyStockMovement[]
  prescriptions           Prescription[]
  serviceTariffs          ServiceTariff[]
  shaClaims               ShaClaim[]
  staff                   Staff[]
  triages                 Triage[]
  userBranchAccesses      UserBranchAccess[]
  userFeedback            UserFeedback[]
  homeUsers               User[]                        @relation("UserHomeFacility")
  wards                   Ward[]

  @@index([latitude, longitude])
  @@index([complianceStatus])
  @@index([complianceGraceEndsAt])
  @@map("facilities")
}

model Branch {
  id                     Int                     @id @default(autoincrement())
  code                   String                  @unique @db.VarChar(50)
  name                   String                  @db.VarChar(150)
  facilityId             Int
  county                 String?                 @db.VarChar(120)
  town                   String?                 @db.VarChar(120)
  country                String?                 @db.VarChar(120)
  phone                  String?                 @db.VarChar(50)
  email                  String?                 @db.VarChar(255)
  address                String?                 @db.VarChar(255)
  postalAddress          String?                 @db.VarChar(255)
  timezone               String?                 @db.VarChar(100)
  currency               String?                 @db.VarChar(20)
  mpesaShortcode         String?                 @db.VarChar(50)
  mpesaPaybill           String?                 @db.VarChar(50)
  mpesaTillNumber        String?                 @db.VarChar(50)
  isDefault              Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  mpesaAccountNumber     String?                 @db.VarChar(80)
  mpesaPochiNumber       String?                 @db.VarChar(80)
  latitude               Float?
  longitude              Float?
  mapLocationLabel       String?                 @db.VarChar(255)
  googleMapsUrl          String?                 @db.VarChar(500)
  admissions             Admission[]
  appointments           Appointment[]
  auditLogs              AuditLog[]
  beds                   Bed[]
  branchMedicineStocks   BranchMedicineStock[]
  facility               Facility                @relation(fields: [facilityId], references: [id])
  clinics                Clinic[]
  consultations          Consultation[]
  departments            Department[]
  dispenses              Dispense[]
  invoices               Invoice[]
  labOrders              LabOrder[]
  notifications          Notification[]
  otcSalePayments        OtcSalePayment[]
  otcSales               OtcSale[]
  payments               Payment[]
  pharmacyStockMovements PharmacyStockMovement[]
  prescriptions          Prescription[]
  serviceTariffs         ServiceTariff[]
  shaClaims              ShaClaim[]
  staffMembers           Staff[]
  triages                Triage[]
  userAccesses           UserBranchAccess[]
  userFeedback           UserFeedback[]
  users                  User[]
  wards                  Ward[]

  @@index([facilityId])
  @@index([latitude, longitude])
  @@map("branches")
}

model Department {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(150)
  facilityId Int
  branchId   Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  clinics    Clinic[]
  branch     Branch?  @relation(fields: [branchId], references: [id])
  facility   Facility @relation(fields: [facilityId], references: [id])
  staff      Staff[]

  @@index([facilityId])
  @@index([branchId])
  @@map("departments")
}

model Role {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff[]
  users       User[]

  @@map("roles")
}

model User {
  id                               Int                   @id @default(autoincrement())
  username                         String                @unique @db.VarChar(50)
  email                            String?               @unique @db.VarChar(255)
  passwordHash                     String                @db.VarChar(255)
  fullName                         String?               @db.VarChar(150)
  isActive                         Boolean               @default(true)
  canAccessAllBranchesInFacility   Boolean               @default(false)
  lastLoginAt                      DateTime?
  createdAt                        DateTime              @default(now())
  updatedAt                        DateTime              @updatedAt
  roleId                           Int
  homeFacilityId                   Int?
  homeBranchId                     Int?
  failedLoginAttempts              Int                   @default(0)
  lockedAt                         DateTime?
  lockReason                       String?               @db.VarChar(255)
  sessionVersion                   Int                   @default(0)
  pendingDeactivationAt            DateTime?
  pendingDeactivationRequestedById Int?
  pendingDeactivationReason        String?               @db.VarChar(255)
  auditLogs                        AuditLog[]            @relation("AuditActorUser")
  resolvedNotifications            Notification[]        @relation("NotificationResolvedByUser")
  notifications                    Notification[]        @relation("NotificationTargetUser")
  passwordResetTokens              PasswordResetToken[]
  patientPortalProfile             Patient?              @relation("PatientPortalUser")
  staff                            Staff?
  branchAccesses                   UserBranchAccess[]
  createdFeedback                  UserFeedback[]        @relation("FeedbackCreatedByUser")
  repliedFeedback                  UserFeedback[]        @relation("FeedbackRepliedByUser")
  locationEvents                   UserLocationEvent[]
  locationProfiles                 UserLocationProfile[]
  reviews                          UserReview?
  sessions                         UserSession[]
  homeBranch                       Branch?               @relation(fields: [homeBranchId], references: [id])
  homeFacility                     Facility?             @relation("UserHomeFacility", fields: [homeFacilityId], references: [id])
  role                             Role                  @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@index([homeFacilityId])
  @@index([homeBranchId])
  @@index([lockedAt])
  @@index([pendingDeactivationAt])
  @@map("users")
}

model UserBranchAccess {
  id         Int      @id @default(autoincrement())
  userId     Int
  facilityId Int
  branchId   Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  branch     Branch   @relation(fields: [branchId], references: [id])
  facility   Facility @relation(fields: [facilityId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, branchId])
  @@index([userId])
  @@index([facilityId])
  @@index([branchId])
  @@map("user_branch_access")
}

model Staff {
  id                          Int                     @id @default(autoincrement())
  staffCode                   String                  @unique @db.VarChar(50)
  firstName                   String                  @db.VarChar(100)
  lastName                    String                  @db.VarChar(100)
  email                       String?                 @unique @db.VarChar(255)
  phone                       String?                 @db.VarChar(30)
  gender                      String?                 @db.VarChar(20)
  designation                 String?                 @db.VarChar(150)
  isClinician                 Boolean                 @default(false)
  isPrescriber                Boolean                 @default(false)
  canLogin                    Boolean                 @default(true)
  isActive                    Boolean                 @default(true)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  facilityId                  Int
  branchId                    Int?
  departmentId                Int?
  roleId                      Int
  userId                      Int?                    @unique
  nationalIdNumber            String?                 @db.VarChar(80)
  nationalIdImageUrl          String?                 @db.LongText
  passportPhotoUrl            String?                 @db.LongText
  clinicianRegistrationNumber String?                 @db.VarChar(120)
  clinicianBoard              String?                 @db.VarChar(160)
  admissions                  Admission[]             @relation("AdmittedByStaff")
  appointments                Appointment[]           @relation("AppointmentDoctor")
  auditLogs                   AuditLog[]              @relation("AuditActorStaff")
  consultations               Consultation[]
  dispenses                   Dispense[]              @relation("DispensedByStaff")
  updatedInvoiceItems         InvoiceItem[]           @relation("InvoiceItemUpdatedBy")
  createdInvoices             Invoice[]               @relation("InvoiceCreatedByStaff")
  ipdDischargeSummaries       IpdDischargeSummary[]   @relation("IpdDischargedBy")
  ipdDoctorReviews            IpdDoctorReview[]       @relation("IpdDoctorReviewedBy")
  ipdProgressNotes            IpdProgressNote[]       @relation("IpdProgressRecordedBy")
  ipdVitalRecords             IpdVitalRecord[]        @relation("IpdVitalRecordedBy")
  labOrders                   LabOrder[]              @relation("LabRequestedBy")
  resolvedNotifications       Notification[]          @relation("NotificationResolvedByStaff")
  notifications               Notification[]          @relation("NotificationTargetStaff")
  otcSalePayments             OtcSalePayment[]        @relation("OtcSalePaymentReceivedByStaff")
  createdOtcSales             OtcSale[]               @relation("OtcSaleCreatedByStaff")
  receivedPayments            Payment[]               @relation("PaymentReceivedByStaff")
  otcStockMovements           PharmacyStockMovement[] @relation("PharmacyStockMovementStaff")
  prescriptions               Prescription[]          @relation("PrescribedByStaff")
  shaClaims                   ShaClaim[]              @relation("ShaClaimCreatedBy")
  branch                      Branch?                 @relation(fields: [branchId], references: [id])
  department                  Department?             @relation(fields: [departmentId], references: [id])
  facility                    Facility                @relation(fields: [facilityId], references: [id])
  role                        Role                    @relation(fields: [roleId], references: [id])
  user                        User?                   @relation(fields: [userId], references: [id])
  administeredTreatments      TreatmentChartEntry[]   @relation("TreatmentAdministeredBy")
  orderedTreatments           TreatmentChartEntry[]   @relation("TreatmentOrderedBy")
  performedTriages            Triage[]                @relation("TriagePerformedBy")
  triageDoctorRoutes          Triage[]                @relation("TriageRoutedDoctor")
  createdFeedback             UserFeedback[]          @relation("FeedbackCreatedByStaff")

  @@index([facilityId])
  @@index([branchId])
  @@index([departmentId])
  @@index([roleId])
  @@index([nationalIdNumber])
  @@index([clinicianBoard])
  @@map("staff_members")
}

model Patient {
  id             Int            @id @default(autoincrement())
  patientNumber  String         @unique @db.VarChar(50)
  firstName      String         @db.VarChar(100)
  middleName     String?        @db.VarChar(100)
  lastName       String         @db.VarChar(100)
  gender         String?        @db.VarChar(20)
  dateOfBirth    DateTime?
  phonePrimary   String?        @db.VarChar(30)
  phoneSecondary String?        @db.VarChar(30)
  email          String?        @db.VarChar(255)
  occupation     String?        @db.VarChar(120)
  isDeceased     Boolean        @default(false)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  facilityId     Int
  portalUserId   Int?           @unique
  admissions     Admission[]
  appointments   Appointment[]
  consultations  Consultation[]
  dispenses      Dispense[]
  invoices       Invoice[]
  labOrders      LabOrder[]
  otcSales       OtcSale[]
  facility       Facility       @relation(fields: [facilityId], references: [id])
  portalUser     User?          @relation("PatientPortalUser", fields: [portalUserId], references: [id])
  prescriptions  Prescription[]
  shaClaims      ShaClaim[]
  triages        Triage[]

  @@index([facilityId])
  @@index([phonePrimary])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([portalUserId])
  @@index([facilityId, createdAt], map: "patients_facility_createdAt_idx")
  @@index([facilityId, patientNumber], map: "patients_facility_patientNumber_idx")
  @@index([facilityId, phonePrimary], map: "patients_facility_phonePrimary_idx")
  @@map("patients")
}

model Clinic {
  id                  Int           @id @default(autoincrement())
  code                String        @unique @db.VarChar(50)
  name                String        @db.VarChar(150)
  clinicType          String        @db.VarChar(50)
  roomLocation        String?       @db.VarChar(150)
  phoneExtension      String?       @db.VarChar(30)
  consultationMinutes Int           @default(15)
  maxDailyCapacity    Int           @default(20)
  serviceStartTime    String?       @db.VarChar(20)
  serviceEndTime      String?       @db.VarChar(20)
  isWalkInAllowed     Boolean       @default(true)
  isReferralRequired  Boolean       @default(false)
  isActive            Boolean       @default(true)
  notes               String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  facilityId          Int
  branchId            Int?
  departmentId        Int
  appointments        Appointment[]
  branch              Branch?       @relation(fields: [branchId], references: [id])
  department          Department    @relation(fields: [departmentId], references: [id])
  facility            Facility      @relation(fields: [facilityId], references: [id])
  triages             Triage[]

  @@index([facilityId])
  @@index([branchId])
  @@index([departmentId])
  @@map("clinics")
}

model Appointment {
  id                Int           @id @default(autoincrement())
  appointmentNumber String        @unique @db.VarChar(50)
  appointmentDate   DateTime
  startTime         String?       @db.VarChar(20)
  endTime           String?       @db.VarChar(20)
  visitReason       String?       @db.Text
  statusCode        String        @db.VarChar(50)
  triagePriority    String?       @db.VarChar(30)
  checkedInAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  facilityId        Int
  branchId          Int?
  patientId         Int
  doctorId          Int?
  clinicId          Int?
  admissions        Admission[]
  branch            Branch?       @relation(fields: [branchId], references: [id])
  clinic            Clinic?       @relation(fields: [clinicId], references: [id])
  doctor            Staff?        @relation("AppointmentDoctor", fields: [doctorId], references: [id])
  facility          Facility      @relation(fields: [facilityId], references: [id])
  patient           Patient       @relation(fields: [patientId], references: [id])
  consultation      Consultation?
  invoices          Invoice[]
  labOrders         LabOrder[]
  triages           Triage?

  @@index([facilityId])
  @@index([branchId])
  @@index([patientId])
  @@index([doctorId])
  @@index([clinicId])
  @@index([statusCode])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([appointmentDate])
  @@index([doctorId, appointmentDate, statusCode], map: "appointments_doctor_date_status_idx")
  @@index([facilityId, branchId, appointmentDate, statusCode], map: "appointments_facility_branch_date_status_idx")
  @@map("appointments")
}

model Triage {
  id                 Int          @id @default(autoincrement())
  triageNumber       String       @unique @db.VarChar(50)
  arrivalType        String?      @db.VarChar(30)
  chiefComplaint     String?      @db.Text
  temperatureC       Float?
  systolicBp         Int?
  diastolicBp        Int?
  pulseRate          Int?
  respiratoryRate    Int?
  oxygenSaturation   Float?
  weightKg           Float?
  heightCm           Float?
  bmi                Float?
  painScore          Int?
  triagePriority     String?      @db.VarChar(30)
  statusCode         String       @default("WAITING_TRIAGE") @db.VarChar(50)
  arrivedAt          DateTime     @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  notes              String?      @db.Text
  facilityId         Int
  branchId           Int?
  patientId          Int
  clinicId           Int?
  appointmentId      Int?         @unique
  performedByStaffId Int?
  routedDoctorId     Int?
  appointment        Appointment? @relation(fields: [appointmentId], references: [id])
  branch             Branch?      @relation(fields: [branchId], references: [id])
  clinic             Clinic?      @relation(fields: [clinicId], references: [id])
  facility           Facility     @relation(fields: [facilityId], references: [id])
  patient            Patient      @relation(fields: [patientId], references: [id])
  performedBy        Staff?       @relation("TriagePerformedBy", fields: [performedByStaffId], references: [id])
  routedDoctor       Staff?       @relation("TriageRoutedDoctor", fields: [routedDoctorId], references: [id])

  @@index([facilityId])
  @@index([branchId])
  @@index([patientId])
  @@index([clinicId])
  @@index([appointmentId])
  @@index([performedByStaffId])
  @@index([routedDoctorId])
  @@index([statusCode])
  @@index([triagePriority])
  @@index([arrivedAt])
  @@map("triage_records")
}

model Consultation {
  id                  Int            @id @default(autoincrement())
  consultationNumber  String         @unique @db.VarChar(50)
  chiefComplaint      String?        @db.Text
  historyOfPresenting String?        @db.Text
  examinationFindings String?        @db.Text
  diagnosis           String?        @db.Text
  treatmentPlan       String?        @db.Text
  notes               String?        @db.Text
  statusCode          String         @default("IN_PROGRESS") @db.VarChar(50)
  startedAt           DateTime       @default(now())
  completedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  facilityId          Int
  branchId            Int?
  appointmentId       Int            @unique
  patientId           Int
  doctorId            Int
  admissions          Admission[]
  appointment         Appointment    @relation(fields: [appointmentId], references: [id])
  branch              Branch?        @relation(fields: [branchId], references: [id])
  doctor              Staff          @relation(fields: [doctorId], references: [id])
  facility            Facility       @relation(fields: [facilityId], references: [id])
  patient             Patient        @relation(fields: [patientId], references: [id])
  invoices            Invoice[]
  prescriptions       Prescription[]

  @@index([facilityId])
  @@index([branchId])
  @@index([patientId])
  @@index([doctorId])
  @@index([statusCode])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([facilityId, branchId, statusCode, startedAt])
  @@index([doctorId, statusCode, startedAt])
  @@map("consultations")
}

model LabTestCatalog {
  id             Int             @id @default(autoincrement())
  testName       String          @db.VarChar(150)
  category       String?         @db.VarChar(100)
  specimenType   String?         @db.VarChar(100)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  orderItems     LabOrderItem[]
  serviceTariffs ServiceTariff[]

  @@index([testName])
  @@index([category])
  @@index([isActive])
  @@index([createdAt])
  @@map("lab_test_catalog")
}

model LabOrder {
  id                 Int            @id @default(autoincrement())
  orderNumber        String         @unique @db.VarChar(50)
  clinicalNotes      String?        @db.Text
  urgency            String?        @db.VarChar(50)
  status             String         @default("REQUESTED") @db.VarChar(50)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  facilityId         Int
  branchId           Int?
  patientId          Int
  appointmentId      Int?
  admissionId        Int?
  encounterRef       String?        @db.VarChar(100)
  requestedByStaffId Int?
  items              LabOrderItem[]
  admission          Admission?     @relation(fields: [admissionId], references: [id])
  appointment        Appointment?   @relation(fields: [appointmentId], references: [id])
  branch             Branch?        @relation(fields: [branchId], references: [id])
  facility           Facility       @relation(fields: [facilityId], references: [id])
  patient            Patient        @relation(fields: [patientId], references: [id])
  requestedBy        Staff?         @relation("LabRequestedBy", fields: [requestedByStaffId], references: [id])

  @@index([facilityId])
  @@index([branchId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([admissionId])
  @@index([requestedByStaffId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([facilityId, branchId, status, createdAt], map: "lab_orders_facility_branch_status_created_idx")
  @@map("lab_orders")
}

model LabOrderItem {
  id           Int            @id @default(autoincrement())
  instructions String?        @db.Text
  status       String         @default("PENDING") @db.VarChar(50)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  orderId      Int
  testId       Int
  order        LabOrder       @relation(fields: [orderId], references: [id])
  test         LabTestCatalog @relation(fields: [testId], references: [id])
  results      LabResult[]

  @@index([orderId])
  @@index([testId])
  @@map("lab_order_items")
}

model LabResult {
  id                 Int          @id @default(autoincrement())
  resultValue        String       @db.Text
  remarks            String?      @db.Text
  recordedBy         Int?
  recordedAt         DateTime     @default(now())
  orderItemId        Int
  attachmentFileName String?      @db.VarChar(255)
  attachmentMimeType String?      @db.VarChar(120)
  attachmentDataUrl  String?      @db.LongText
  orderItem          LabOrderItem @relation(fields: [orderItemId], references: [id])

  @@index([orderItemId])
  @@index([recordedAt])
  @@index([recordedBy])
  @@map("lab_results")
}

model Medicine {
  id                Int                     @id @default(autoincrement())
  code              String                  @unique @db.VarChar(50)
  name              String                  @db.VarChar(150)
  dosageForm        String?                 @db.VarChar(100)
  strength          String?                 @db.VarChar(100)
  manufacturer      String?                 @db.VarChar(150)
  unitPrice         Float?                  @default(0)
  stockQuantity     Int                     @default(0)
  reorderLevel      Int                     @default(0)
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  branchStocks      BranchMedicineStock[]
  dispenseItems     DispenseItem[]
  otcSaleItems      OtcSaleItem[]
  stockMovements    PharmacyStockMovement[]
  prescriptionItems PrescriptionItem[]

  @@index([name])
  @@index([isActive])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("medicines")
}

model Prescription {
